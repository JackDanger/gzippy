{
  "input": "benchmark_data/silesia-large.gz",
  "threads": [1, 2, 3, 4, 5, 6, 8, 12, 16],
  "samples": 7,
  "reference": "gzippy",
  "tools": [
    {
      "name": "gzippy",
      "bin": "./target/release/gzippy",
      "argv": ["-d", "-c", "{input}"],
      "thread_arg": "-p{n}",
      "trace_env": "GZIPPY_TIMELINE"
    },
    {
      "name": "rapidgzip",
      "bin": "./vendor/rapidgzip/librapidarchive/build/src/tools/rapidgzip",
      "argv": ["-d", "-c", "{input}"],
      "thread_arg": "-P{n}",
      "trace_env": "GZIPPY_TIMELINE"
    }
  ]
}

#!/usr/bin/env bash
# fulcrum — the campaign's instrument front door.
# Engine: the fulcrum OSS repo's decide/ package ($FULCRUM_HOME/decide;
# FULCRUM_HOME defaults to $HOME/www/fulcrum).
#
#   fulcrum decide [args]      ONE-RUN decision table on the bench box
#                              (scripts/bench/decide.sh; plans/fulcrum-product.md)
#   fulcrum analyze <dir>      re-render table + decision brief from artifacts
#   fulcrum total <trace...>   the validated whole-system trace analyzer
#   fulcrum selftest           run ALL suites (trace, decide, invariants);
#                              writes the SELF-TEST-OR-NO-TRUST stamp
#   fulcrum invariants         the enforced invariant set, with scars
#   fulcrum ledger [path]      banked results + fingerprints
#   fulcrum score [args]       generate a score/ cell deterministically
#                              (see `fulcrum score` for the full arg list)
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FULCRUM_HOME="${FULCRUM_HOME:-$HOME/www/fulcrum}"
PKG="$FULCRUM_HOME/decide"
if [ ! -d "$PKG/fulcrum" ]; then
  echo "fulcrum: decision engine not found at $PKG (set FULCRUM_HOME; default \$HOME/www/fulcrum)" >&2
  exit 1
fi
export FULCRUM_LEDGER="${FULCRUM_LEDGER:-$HERE/../artifacts/fulcrum/ledger.jsonl}"

cmd="${1:-help}"; shift || true
case "$cmd" in
  decide)   exec "$HERE/bench/decide.sh" "$@";;
  analyze)  exec python3 "$HERE/fulcrum_decide.py" "$@";;
  total)    exec python3 "$HERE/fulcrum_total.py" "$@";;
  selftest|invariants|ledger)
    exec env PYTHONPATH="$PKG${PYTHONPATH:+:$PYTHONPATH}" \
      python3 -m fulcrum.cli "$cmd" "$@";;
  score)
    # `fulcrum score` is implemented in the Rust fulcrum binary.
    FULCRUM_BIN="$FULCRUM_HOME/target/release/fulcrum"
    if [ ! -x "$FULCRUM_BIN" ]; then
      echo "fulcrum score: binary not found at $FULCRUM_BIN" >&2
      echo "  Build it first: cd '$FULCRUM_HOME' && cargo build --release" >&2
      exit 1
    fi
    exec "$FULCRUM_BIN" score "$@";;
  *) sed -n '2,13p' "${BASH_SOURCE[0]}";;
esac

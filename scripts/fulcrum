#!/usr/bin/env bash
# fulcrum — the campaign's instrument front door (engine: tools/fulcrum).
#
#   fulcrum decide [args]      ONE-RUN decision table on the bench box
#                              (scripts/bench/decide.sh; plans/fulcrum-product.md)
#   fulcrum analyze <dir>      re-render table + decision brief from artifacts
#   fulcrum total <trace...>   the validated whole-system trace analyzer
#   fulcrum selftest           run ALL suites (trace, decide, invariants);
#                              writes the SELF-TEST-OR-NO-TRUST stamp
#   fulcrum invariants         the enforced invariant set, with scars
#   fulcrum ledger [path]      banked results + fingerprints
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PKG="$HERE/../tools/fulcrum"
export FULCRUM_LEDGER="${FULCRUM_LEDGER:-$HERE/../artifacts/fulcrum/ledger.jsonl}"

cmd="${1:-help}"; shift || true
case "$cmd" in
  decide)   exec "$HERE/bench/decide.sh" "$@";;
  analyze)  exec python3 "$HERE/fulcrum_decide.py" "$@";;
  total)    exec python3 "$HERE/fulcrum_total.py" "$@";;
  selftest|invariants|ledger)
    exec env PYTHONPATH="$PKG${PYTHONPATH:+:$PYTHONPATH}" \
      python3 -m fulcrum.cli "$cmd" "$@";;
  *) sed -n '2,12p' "${BASH_SOURCE[0]}";;
esac
